{
  "expo": {
    "name": "PLOD",
    "slug": "plod",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/plod-thread-icon.png",
    "scheme": "plod",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#141210",
        "foregroundImage": "./assets/images/plod-thread-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/plod-thread-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141210",
          "image": "./assets/images/plod-thread-icon.png",
          "imageWidth": 180
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
